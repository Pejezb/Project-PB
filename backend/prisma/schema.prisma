generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl → pooler session mode (puerto 5432) para migraciones/db push.
  // Runtime usa DATABASE_URL con pgbouncer (puerto 6543).
  directUrl = env("DIRECT_URL")
}

model Sucursal {
  id              String   @id @default(cuid())
  nombre          String
  direccion       String?
  telefono        String?

  abierto         Boolean  @default(false)

  horarioApertura String?
  horarioCierre   String?
  diasOperacion   String?

  duenoId         String
  dueno           Usuario  @relation("DuenoSucursal", fields: [duenoId], references: [id])

  usuarios        Usuario[] @relation("UsuarioSucursal")
  mesas           Mesa[]
  categorias      Categoria[]
  productos       Producto[]
  pedidos         Pedido[]
  asistencias     Asistencia[]

  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)

  intentosFallidos  Int       @default(0)
  bloqueadoHasta    DateTime?

  sucursalId   String?
  sucursal     Sucursal? @relation("UsuarioSucursal", fields: [sucursalId], references: [id], onDelete: Cascade)

  duenoDe      Sucursal[] @relation("DuenoSucursal")

  pedidos      Pedido[]
  asistencias  Asistencia[]
  creadoEn     DateTime @default(now())
}

model Asistencia {
  id            String   @id @default(cuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sucursalId    String
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  fecha         DateTime @db.Date
  presente      Boolean  @default(false)
  tardanza      Boolean  @default(false)
  horaEntrada   DateTime?
  horaSalida    DateTime?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([usuarioId, fecha])
}


enum Rol {
  ADMIN    // Gestiona su sucursal, puede abrir/cerrar
  MESERO   // Toma pedidos, añade items, cobra
  COCINERO // Ve y marca pedidos listos en cocina
  DUENO
}

model Mesa {
  id         String     @id @default(cuid())
  numero     Int
  capacidad  Int        @default(4)
  estado     EstadoMesa @default(LIBRE)

  sucursalId String
  sucursal   Sucursal   @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  pedidos    Pedido[]

  @@unique([numero, sucursalId])
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  RESERVADA
}

// ── Categoria ─────────────────────────────────────────────────────────────────
model Categoria {
  id         String     @id @default(cuid())
  nombre     String
  sucursalId String
  sucursal   Sucursal   @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  productos  Producto[]
}

// ── Producto ──────────────────────────────────────────────────────────────────
model Producto {
  id             String      @id @default(cuid())
  nombre         String
  descripcion    String?
  precio         Decimal
  imagen         String?
  disponible     Boolean     @default(true)
  requiereCocina Boolean     @default(true)
  categoriaId    String
  categoria      Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  sucursalId     String
  sucursal       Sucursal    @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  itemsPedido    ItemPedido[]
}

// ── Pedido ────────────────────────────────────────────────────────────────────
model Pedido {
  id            String       @id @default(cuid())
  numero        Int          @default(autoincrement())
  tipo          TipoPedido
  estado        EstadoPedido @default(PENDIENTE)
  mesaId        String?
  mesa          Mesa?        @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  meseroId      String?
  mesero        Usuario?     @relation(fields: [meseroId], references: [id], onDelete: SetNull)
  sucursalId    String
  sucursal      Sucursal     @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  items         ItemPedido[]
  pagado        Boolean      @default(false)
  metodoPago    String?
  total         Decimal?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
}

enum TipoPedido {
  EN_MESA
  PARA_LLEVAR
}

enum EstadoPedido {
  PENDIENTE
  EN_COCINA
  LISTO
  ENTREGADO
  PAGADO
  CANCELADO
}

// ── ItemPedido ────────────────────────────────────────────────────────────────
model ItemPedido {
  id         String   @id @default(cuid())
  pedidoId   String
  pedido     Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  cantidad   Int
  precio     Decimal
  subtotal   Decimal
  servido    Boolean  @default(false)
}